# Stack AI locale - Ollama + Open WebUI
# Lasciare i default per avvio rapido su host singolo.

# UI Web
OLLAMA_UI_PORT=8011
WEBUI_NAME=Moana
WEBUI_AUTH=True
ENABLE_SIGNUP=False
DEFAULT_USER_ROLE=user

# Runtime Ollama (risorse ridotte)
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Note
# 1) Nessuna esposizione host per API ollama (porta 11434 solo interna).
# 2) Modelli e dati persistono in ${APPDATA_DIR}/ollama/.
