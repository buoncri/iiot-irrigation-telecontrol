# Stack formazione - Paperless-ngx (documenti per training)
# Variabili opzionali: lascia commentate per usare i default del compose.
# TZ=Europe/Rome

# Credenziali DB interne allo stack
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=paperless

# Primo utente admin Paperless (usato solo al primo bootstrap DB)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=admin

# OCR e URL
PAPERLESS_OCR_LANGUAGE=ita+eng
# PAPERLESS_URL=http://192.168.0.6:8018
