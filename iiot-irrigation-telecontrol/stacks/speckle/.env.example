# Configurazione Globale Sistema
SYS_IP=172.23.54.212
SYS_DOMAIN=telecontrollo.local
APPDATA_DIR=/home/luca/Docker/iiot-irrigation-telecontrol/appdata

# Speckle - Accesso
SPECKLE_PORT=3030
SPECKLE_CANONICAL_URL=http://172.23.54.212:3030
SPECKLE_SERVER_NAME=local
SPECKLE_SSL_ENABLED=false

# Speckle - Sicurezza (OBBLIGATORIO: cambiare in produzione)
SPECKLE_SESSION_SECRET=change-me-to-a-long-random-string

# Speckle - Database Postgres
SPECKLE_POSTGRES_DB=speckle
SPECKLE_POSTGRES_USER=speckle
SPECKLE_POSTGRES_PASSWORD=speckle

# Speckle - MinIO (Object Storage)
SPECKLE_MINIO_PORT=9000
SPECKLE_MINIO_ACCESS_KEY=minioadmin
SPECKLE_MINIO_SECRET_KEY=minioadmin
SPECKLE_S3_PUBLIC_ENDPOINT=http://172.23.54.212:9000

# Speckle - Email (opzionale, disabilitata di default)
SPECKLE_EMAIL_ENABLED=false
SPECKLE_EMAIL_HOST=smtp.example.com
SPECKLE_EMAIL_PORT=587
SPECKLE_EMAIL_USERNAME=
SPECKLE_EMAIL_PASSWORD=
SPECKLE_EMAIL_SECURE=false
SPECKLE_EMAIL_REQUIRE_TLS=true
SPECKLE_EMAIL_FROM=noreply@example.com
