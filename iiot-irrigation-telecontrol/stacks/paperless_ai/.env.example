# Stack Paperless-AI (pilot)
# Copia in .env e compila i valori necessari.

SYS_IP=192.168.0.6
APPDATA_DIR=/opt/iiot-irrigation-telecontrol/appdata
TZ=Europe/Rome

# Porta UI Paperless-AI
PAPERLESS_AI_PORT=8019

# Paperless locale (interno rete docker)
PAPERLESS_API_URL=http://paperless:8000/api
PAPERLESS_API_TOKEN=
PAPERLESS_USERNAME=admin

# Provider AI locale
AI_PROVIDER=ollama
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Pilot-safe defaults
DISABLE_AUTOMATIC_PROCESSING=yes
ADD_AI_PROCESSED_TAG=no
AI_PROCESSED_TAG_NAME=pilot-ppai-processed
PROCESS_PREDEFINED_DOCUMENTS=no
ACTIVATE_TAGGING=no
ACTIVATE_CORRESPONDENTS=no
ACTIVATE_DOCUMENT_TYPE=no
ACTIVATE_TITLE=no
ACTIVATE_CUSTOM_FIELDS=no
USE_PROMPT_TAGS=no
PROMPT_TAGS=pilot-ppai
SCAN_INTERVAL=0 0 * * 0
