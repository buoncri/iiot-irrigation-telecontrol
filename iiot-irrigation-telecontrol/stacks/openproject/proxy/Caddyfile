:80 {
    # Prima gestisci hocuspocus
    reverse_proxy /hocuspocus* hocuspocus:1234

    # Poi tutto il resto a web
    reverse_proxy * web:8080 {
        # IMPORTANTE: imposta l'Host header
        header_up Host {host}
        header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        header_up X-Forwarded-For {header.X-Forwarded-For}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Port {header.X-Forwarded-Port}
    }

    file_server
    log
}
