# Stack Cheshire Cat (Stregatto)
# Copia in .env e compila i valori necessari.

SYS_IP=192.168.0.6
APPDATA_DIR=/opt/iiot-irrigation-telecontrol/appdata
TZ=Europe/Rome

# Porte servizio
CHESHIRE_CAT_PORT=1865
CHESHIRE_CAT_DEBUG_PORT=5678

# Integrazione Paperless (flow documentale)
PAPERLESS_API_URL=http://paperless:8000/api
PAPERLESS_API_TOKEN=
